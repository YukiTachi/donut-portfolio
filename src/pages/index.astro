  .hero__glow--accent {
    top: -100px; right: -120px; width: 480px; height: 480px;
    background: radial-gradient(circle, rgba(212, 82, 58, 0.15) 0%, transparent 70%);
  }
  .hero__glow--green {
    bottom: -160px; left: -80px; width: 360px; height: 360px;
    background: radial-gradient(circle, rgba(58, 93, 79, 0.2) 0%, transparent 70%);
  }

  .badge {
    display: inline-flex; align-items: center; gap: 10px; padding: 6px 14px;
    background: rgba(212, 82, 58, 0.12); color: var(--c-accent);
    border-radius: 999px; font-size: 12px; font-weight: 500; margin-bottom: 32px;
  }
  .badge__dot {
    width: 6px; height: 6px; background: var(--c-accent);
    border-radius: 50%; animation: r-pulse 2s ease-in-out infinite;
  }

  .hero__grid {
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 64px; align-items: center;
  }
  .hero__title {
    font-family: var(--ff-serif); font-size: clamp(56px, 8vw, 108px);
    font-weight: 400; margin: 0; letter-spacing: -0.03em; line-height: 0.98;
  }
  .hero__line { display: block; white-space: nowrap; }
  .hero__hi { position: relative; display: inline-block; color: var(--c-accent); }
  .hero__squiggle {
    position: absolute; left: -4px; bottom: -10px; width: 100px;
    color: var(--c-accent);
  }
  .reveal-letter {
    display: inline-block;
    opacity: 0;
    transform: translateY(40%);
    animation: r-reveal-y .7s cubic-bezier(.2, .7, .3, 1) forwards;
  }
  .reveal-letter.is-italic { font-style: italic; }

  .hero__lede {
    font-family: var(--ff-sans); font-size: 18px; line-height: 1.7;
    color: var(--c-muted); max-width: 560px; margin-top: 64px;
    text-wrap: pretty;
  }
  .hero__cta { display: flex; gap: 12px; margin-top: 36px; flex-wrap: wrap; }
  .btn {
    padding: 16px 28px; border-radius: 999px; font-size: 14px; font-weight: 500;
    text-decoration: none; display: inline-flex; gap: 8px; align-items: center;
    transition: transform .2s, box-shadow .2s;
  }
  .btn--solid { background: var(--c-ink); color: var(--c-cream); }
  .btn--solid:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(34, 26, 63, 0.25); }
  .btn--ghost { background: transparent; color: var(--c-ink); border: 1px solid var(--c-rule); }
  .btn--ghost:hover { background: var(--c-faint); }
  .btn__arrow { font-style: italic; }

  .hero__portrait-wrap { justify-self: end; }
  .portrait {
    position: relative; width: 400px; aspect-ratio: 1 / 1.24;
  }
  .portrait__bg {
    position: absolute; inset: -16px; background: var(--c-accent);
    border-radius: 16px;
    transform: rotate(-3deg) translate(var(--px, 0), var(--py, 0));
    z-index: 0;
  }
  .portrait__img {
    position: relative; z-index: 1;
    width: 100%; height: 100%; object-fit: cover;
    border-radius: 12px;
    border: 1px solid rgba(34, 26, 63, 0.1);
    transform: translate(var(--px, 0), var(--py, 0));
  }
  .portrait__tag {
    position: absolute; padding: 14px 18px; border-radius: 12px;
    border: 1px solid var(--c-rule);
    box-shadow: 0 8px 28px rgba(34, 26, 63, 0.18);
    z-index: 2;
  }
  .portrait__tag--bl {
    bottom: -28px; left: -28px; background: var(--c-cream);
    transform: rotate(-3deg);
  }
  .portrait__tag--tr {
    top: -20px; right: -32px; background: var(--c-ink); color: var(--c-cream);
    transform: rotate(4deg);
  }
  .portrait__tag-eyebrow {
    font-family: var(--ff-mono); font-size: 10px; letter-spacing: 0.16em;
    color: var(--c-muted); margin-bottom: 4px; text-transform: uppercase;
  }
  .portrait__tag--tr .portrait__tag-eyebrow { color: rgba(244, 237, 224, 0.7); }
  .portrait__tag-text {
    font-family: var(--ff-serif); font-size: 15px; font-style: italic;
    color: var(--c-ink);
  }
  .portrait__tag-big {
    font-family: var(--ff-serif); font-size: 22px; font-style: italic;
  }
  .portrait__tag-big span { font-size: 12px; opacity: 0.7; }

  .meta-rail {
    margin-top: 80px; padding-top: 32px; border-top: 1px solid var(--c-rule);
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px;
  }
  .meta-rail__mono {
    font-family: var(--ff-mono); font-size: 11px; letter-spacing: 0.12em;
    color: var(--c-muted); text-transform: uppercase; margin-bottom: 4px;
  }
  .meta-rail__text {
    color: var(--c-ink); font-family: var(--ff-sans); font-size: 13px;
  }

  @media (max-width: 900px) {
    .hero__grid { grid-template-columns: 1fr; gap: 48px; }
    .hero__portrait-wrap { justify-self: start; }
    .portrait { width: 280px; }
    .meta-rail { grid-template-columns: repeat(2, 1fr); }
  }

  /* PHILOSOPHY */
  .philo {
    padding: 48px 0; background: var(--c-ink); color: var(--c-cream);
    overflow: hidden;
  }
  .philo__track {
    display: flex; animation: r-marquee 50s linear infinite; white-space: nowrap;
  }
  .philo__group {
    display: inline-flex; gap: 56px; padding-right: 56px;
    font-family: var(--ff-serif); font-size: 56px; font-weight: 300;
    font-style: italic; letter-spacing: -0.015em;
  }
  .philo__sep { color: var(--c-accent); font-style: normal; }
  .philo__faded { color: rgba(244, 237, 224, 0.5); }

  /* ABOUT */
  .about__grid {
    display: grid; grid-template-columns: 1fr 1.5fr; gap: 80px; margin-top: 64px;
  }
  .about__quote {
    font-family: var(--ff-serif); font-size: 28px; line-height: 1.55;
    font-style: italic; color: var(--c-accent);
    padding-left: 24px; border-left: 3px solid var(--c-accent);
  }
  .about__attrib {
    margin-top: 32px; font-family: var(--ff-mono); font-size: 11px;
    letter-spacing: 0.18em; color: var(--c-muted); text-transform: uppercase;
  }
  .about__p {
    font-family: var(--ff-serif); font-size: 19px; line-height: 1.75;
    margin: 0 0 16px 0; text-wrap: pretty;
  }
  @media (max-width: 900px) {
    .about__grid { grid-template-columns: 1fr; gap: 40px; }
  }

  /* WALK */
  .walk { background: var(--c-paper); overflow: hidden; }
  .walk__grid {
    margin-top: 56px; display: grid; grid-template-columns: 1fr 1fr;
    gap: 64px; align-items: start;
  }
  .walk__p {
    font-family: var(--ff-serif); font-size: 18px; line-height: 1.75;
    color: var(--c-muted); margin-top: 16px;
  }
  .walk__p--lead {
    font-size: 26px; line-height: 1.55; color: var(--c-ink); margin: 0;
    text-wrap: pretty;
  }

  .chart {
    background: var(--c-cream); padding: 32px; border-radius: 20px;
    border: 1px solid var(--c-rule);
    box-shadow: 0 8px 32px rgba(34, 26, 63, 0.06);
  }
  .chart__head {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 24px;
  }
  .chart__eyebrow {
    font-family: var(--ff-mono); font-size: 10px; letter-spacing: 0.18em;
    color: var(--c-muted); text-transform: uppercase;
  }
  .chart__big {
    font-family: var(--ff-serif); font-size: 44px; font-weight: 500;
    margin-top: 4px; line-height: 1; letter-spacing: -0.02em;
  }
  .chart__big-sub {
    font-size: 14px; color: var(--c-muted); font-weight: 400; font-style: italic;
    margin-left: 4px;
  }
  .chart__legend {
    text-align: right; font-family: var(--ff-mono); font-size: 10px;
    color: var(--c-muted); letter-spacing: 0.1em; line-height: 1.6;
  }
  .chart__peak {
    color: var(--c-accent); font-size: 13px; font-family: var(--ff-serif);
    font-style: italic; margin-left: 4px;
  }
  .chart__low {
    color: var(--c-ink); font-size: 13px; font-family: var(--ff-serif);
    margin-left: 4px;
  }
  .chart__svg { display: block; width: 100%; overflow: visible; }
  .chart__area { opacity: 0; transition: opacity 1s; }
  .chart__area.is-drawn { opacity: 1; }
  .chart__line { transition: stroke-dashoffset 2s ease-out; }
  .chart__line.is-drawn { stroke-dashoffset: 0 !important; }
  .chart__dot { opacity: 0; transition: opacity .5s; }
  .chart__dot.is-drawn { opacity: 1; }
  .chart__axis {
    font-family: var(--ff-mono); font-size: 10px;
    fill: var(--c-muted); letter-spacing: 0.1em;
  }
  .chart__axis--end { text-anchor: end; }

  .stats {
    margin-top: 80px; display: grid; grid-template-columns: repeat(6, 1fr);
    gap: 12px;
  }
  .stat-card {
    background: var(--c-cream); color: var(--c-ink);
    padding: 28px 20px; border-radius: 16px; border: 1px solid var(--c-rule);
    transition: all .3s cubic-bezier(.2, .7, .3, 1);
  }
  .stat-card:hover {
    background: var(--c-ink); color: var(--c-cream);
    transform: translateY(-6px);
    box-shadow: 0 16px 32px rgba(34, 26, 63, 0.18);
  }
  .stat-card__num {
    font-family: var(--ff-serif); font-size: 44px; font-weight: 500;
    line-height: 1; letter-spacing: -0.025em;
  }
  .stat-card__unit {
    font-size: 18px; color: var(--c-accent); margin-left: 4px;
    font-weight: 400; font-style: italic;
  }
  .stat-card__label { font-size: 12px; margin-top: 12px; }
  .stat-card__en {
    font-family: var(--ff-mono); font-size: 9px; margin-top: 4px;
    opacity: 0.55; letter-spacing: 0.08em;
  }
  @media (max-width: 1100px) {
    .stats { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 900px) {
    .walk__grid { grid-template-columns: 1fr; gap: 40px; }
    .stats { grid-template-columns: repeat(2, 1fr); }
  }

  /* STACK */
  .stack__list { margin-top: 64px; position: relative; }
  .stack__rail {
    position: absolute; left: 28px; top: 30px; bottom: 30px;
    width: 2px; background: var(--c-accent); opacity: 0.25;
  }
  .stack__row {
    display: grid; grid-template-columns: 60px 240px 1fr; gap: 32px;
    align-items: center; padding: 24px 0; position: relative;
  }
  .stack__num {
    width: 56px; height: 56px; border-radius: 50%; background: var(--c-cream);
    border: 2px solid var(--c-accent);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--ff-serif); font-size: 22px; color: var(--c-accent);
    font-weight: 500; font-style: italic;
    position: relative; z-index: 1;
  }
  .stack__name {
    font-family: var(--ff-serif); font-size: 32px; font-weight: 500; line-height: 1.1;
  }
  .stack__layer {
    font-family: var(--ff-mono); font-size: 11px; color: var(--c-muted);
    margin-top: 4px; letter-spacing: 0.1em;
  }
  .stack__items { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip {
    font-family: var(--ff-mono); font-size: 12px; padding: 8px 14px;
    background: var(--c-cream); border: 1px solid var(--c-rule); border-radius: 8px;
  }
  .chip--xs { font-size: 10px; padding: 3px 8px; border-radius: 4px; }
  @media (max-width: 900px) {
    .stack__row { grid-template-columns: 56px 1fr; row-gap: 12px; }
    .stack__items { grid-column: 1 / -1; padding-left: 0; }
    .stack__rail { left: 28px; }
  }

  /* EXPERIENCE */
  .experience { background: var(--c-ink); color: var(--c-cream); }
  .exp__grid {
    margin-top: 64px; display: grid; grid-template-columns: 1fr 1fr; gap: 32px;
  }
  .exp__card {
    background: rgba(244, 237, 224, 0.06); color: var(--c-cream);
    padding: 40px; border-radius: 20px;
    border: 1px solid rgba(244, 237, 224, 0.12);
    transition: transform .3s;
  }
  .exp__card:hover { transform: translateY(-4px); }
  .exp__card--accent { background: var(--c-accent); border: none; }
  .exp__period {
    font-family: var(--ff-mono); font-size: 11px; letter-spacing: 0.18em;
    opacity: 0.8; text-transform: uppercase;
  }
  .exp__org {
    font-family: var(--ff-serif); font-size: 44px; font-weight: 500;
    margin: 16px 0 4px 0;
  }
  .exp__role { font-size: 13px; opacity: 0.85; margin-bottom: 28px; }
  .exp__summary {
    font-family: var(--ff-serif); font-size: 17px; line-height: 1.65; opacity: 0.95;
  }
  .exp__bar {
    display: flex; gap: 0; height: 8px; border-radius: 4px;
    overflow: hidden; margin: 8px 0 16px;
  }
  .exp__alloc {
    display: flex; align-items: flex-start; gap: 24px; font-size: 12px; margin-bottom: 24px;
  }
  .exp__alloc > div { flex: 1; }
  .exp__alloc-pct {
    font-family: var(--ff-serif); font-size: 22px; font-weight: 500;
  }
  .exp__alloc-label { opacity: 0.85; }
  .exp__alloc-sub { margin-top: 2px; font-size: 11px; line-height: 1.4; opacity: 0.55; }
  .exp__work { list-style: none; padding: 0; margin: 0; }
  .exp__work li {
    padding: 12px 0; border-top: 1px solid rgba(244, 237, 224, 0.18);
    font-size: 14px; display: flex; gap: 12px;
  }
  .exp__work-num { font-family: var(--ff-mono); opacity: 0.6; }
  @media (max-width: 900px) {
    .exp__grid { grid-template-columns: 1fr; }
    .exp__alloc { flex-direction: column; gap: 16px; }
  }

  /* SKILLS */
  .skills__grid {
    margin-top: 56px; display: grid; grid-template-columns: 300px 1fr; gap: 32px;
  }
  .skills__tabs { display: flex; flex-direction: column; gap: 4px; }
  .skills__tab {
    text-align: left; padding: 16px 20px; border: none;
    background: transparent; color: var(--c-ink);
    border-radius: 10px; font-family: var(--ff-sans); font-size: 14px;
    font-weight: 500; transition: all .2s;
    display: flex; align-items: center; gap: 12px;
  }
  .skills__tab.is-active { background: var(--c-ink); color: var(--c-cream); }
  .skills__tab-num {
    font-family: var(--ff-mono); font-size: 10px; opacity: 0.5;
    width: 22px; color: var(--c-muted);
  }
  .skills__tab.is-active .skills__tab-num { color: var(--c-accent); opacity: 0.8; }
  .skills__tab-body { flex: 1; display: block; text-align: left; }
  .skills__tab-title { display: block; }
  .skills__tab-ja { display: block; font-size: 11px; opacity: 0.65; margin-top: 2px; }
  .skills__tab-arrow { color: var(--c-accent); font-size: 14px; opacity: 0; }
  .skills__tab.is-active .skills__tab-arrow { opacity: 1; }

  .skills__panels { position: relative; min-height: 400px; }
  .skills__panel {
    background: var(--c-paper); border-radius: 20px; padding: 40px;
    border: 1px solid var(--c-rule);
    display: none;
  }
  .skills__panel.is-active { display: block; }
  .skills__panel-eyebrow {
    font-family: var(--ff-mono); font-size: 11px; color: var(--c-accent);
    letter-spacing: 0.18em; margin-bottom: 8px; text-transform: uppercase;
  }
  .skills__panel-title {
    font-family: var(--ff-serif); font-size: 40px; font-weight: 500;
    margin: 0 0 28px 0;
  }
  .skills__items { list-style: none; padding: 0; margin: 0; }
  .skills__items li {
    padding: 16px 0; border-top: 1px solid var(--c-rule);
    display: flex; align-items: baseline; gap: 16px;
  }
  .skills__item-num {
    font-family: var(--ff-mono); font-size: 11px; color: var(--c-muted); width: 30px;
  }
  .skills__item-body { flex: 1; }
  .skills__item-name { font-family: var(--ff-serif); font-size: 18px; }
  .skills__item-desc { font-size: 13px; color: var(--c-muted); margin-top: 2px; }
  .skills__item-years {
    font-family: var(--ff-serif); font-style: italic; color: var(--c-accent);
    font-size: 18px;
  }
  @media (max-width: 900px) {
    .skills__grid { grid-template-columns: 1fr; }
    .skills__panels { min-height: auto; }
  }

  /* BRAINSYNC */
  .brainsync { background: var(--c-paper); }

  /* Featured index strip (06.1 / 06.2) */
  .feat__index {
    margin: 56px 0 20px; display: flex;
    justify-content: space-between; align-items: baseline;
    border-top: 1px solid var(--c-rule); padding-top: 18px;
  }
  .feat__index-left { display: flex; align-items: baseline; gap: 16px; }
  .feat__index-n {
    font-family: var(--ff-mono); font-size: 12px;
    letter-spacing: 0.16em; color: var(--c-muted);
  }
  .feat__index-name {
    font-family: var(--ff-serif); font-size: 18px;
    font-style: italic; color: var(--c-ink);
  }
  .feat__index-status {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--ff-mono); font-size: 11px; letter-spacing: 0.16em;
    color: var(--c-accent); text-transform: uppercase;
  }
  .feat__index--warm .feat__index-status { color: var(--c-warm); }
  .feat__index-dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--c-accent);
  }
  .feat__index-live {
    width: 8px; height: 8px; border-radius: 50%; background: var(--c-warm);
    box-shadow: 0 0 0 4px rgba(91, 122, 74, 0.12);
    animation: r-pulse 2s ease-in-out infinite;
  }
  .feat__divider {
    margin-top: 96px; margin-bottom: 8px; height: 1px; background: var(--c-rule);
  }

  .bs__hero {
    background: var(--c-ink); color: var(--c-cream);
    border-radius: 32px; padding: 56px;
    display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px;
    align-items: center; position: relative; overflow: hidden;
  }
  .bs__neural {
    position: absolute; right: -120px; top: -80px;
    width: 720px; height: 720px; opacity: 0.08; pointer-events: none;
  }
  .bs__hero-left { position: relative; z-index: 1; }
  .bs__hero-right { position: relative; z-index: 1; }
  .bs__title {
    font-family: var(--ff-serif); font-size: 92px; font-weight: 500;
    margin: 0 0 16px 0; letter-spacing: -0.03em; line-height: 1;
  }
  .bs__tag {
    font-family: var(--ff-serif); font-style: italic; font-size: 24px;
    color: var(--c-accent); margin-bottom: 28px;
  }
  .bs__desc {
    font-family: var(--ff-serif); font-size: 18px; line-height: 1.7;
    opacity: 0.95; max-width: 540px;
  }
  .bs__meta {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 36px;
  }
  .bs__meta-k {
    font-family: var(--ff-mono); font-size: 10px; opacity: 0.6;
    letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 6px;
    border-top: 1px solid rgba(244, 237, 224, 0.2); padding-top: 14px;
  }
  .bs__meta-v { font-size: 13px; font-family: var(--ff-serif); }

  .bs__mock {
    background: rgba(244, 237, 224, 0.06); border-radius: 20px; padding: 28px;
    border: 1px solid rgba(244, 237, 224, 0.18);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  }
  .bs__mock-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px;
  }
  .bs__mock-eyebrow {
    font-family: var(--ff-mono); font-size: 10px; opacity: 0.7;
    letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 4px;
  }
  .bs__mock-title { font-family: var(--ff-serif); font-size: 24px; font-weight: 500; }
  .bs__mock-score {
    font-family: var(--ff-serif); font-style: italic; color: var(--c-accent);
    font-size: 32px;
  }
  .bs__mock-score span { font-size: 14px; }
  .bs__mock-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 20px;
  }
  .bs__cell {
    aspect-ratio: 1; border-radius: 8px;
    background: rgba(244, 237, 224, 0.06);
    border: 1px solid rgba(244, 237, 224, 0.15);
    transition: background .4s;
  }
  .bs__cell.is-on { background: var(--c-accent); }
  .bs__mock-metrics {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
  }
  .bs__metric-label {
    font-family: var(--ff-mono); font-size: 9px; opacity: 0.6;
    letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 6px;
  }
  .bs__metric-bar {
    height: 4px; background: rgba(244, 237, 224, 0.15);
    border-radius: 2px; overflow: hidden;
  }
  .bs__metric-fill { height: 100%; transition: width 1s; }
  .bs__metric-fill--accent { background: var(--c-accent); }
  .bs__metric-fill--cream { background: var(--c-cream); }
  .bs__metric-fill--muted { background: rgba(244, 237, 224, 0.6); }
  .bs__metric-num { font-family: var(--ff-serif); font-size: 14px; margin-top: 4px; }
  .bs__mock-caption {
    font-family: var(--ff-mono); font-size: 10px;
    color: rgba(244, 237, 224, 0.5); letter-spacing: 0.16em;
    text-align: center; margin-top: 12px; text-transform: uppercase;
  }

  .bs__reasons {
    margin-top: 56px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }
  .bs__reason {
