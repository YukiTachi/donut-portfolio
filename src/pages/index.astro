    stack: [],
  },
];

const LIFE_INTERESTS = [
  { ja: '音楽', en: 'Music', body: 'ジャズ（Bill Evans, Miles Davis）。作業中の BGM は常にジャズ。' },
  { ja: '読書', en: 'Reading', body: '哲学（Viktor Frankl『夜と霧』等）、認知科学、イノベーション理論（『独創はひらめかない』等）。' },
  { ja: 'コレクション', en: 'Collecting', body: 'アナログとデジタルの接点に魅力を感じる。' },
];

const LIFE_BALANCE = [
  { k: '平日', v: 'クライアントワーク + 開発' },
  { k: '週末', v: '個人プロジェクト + リサーチ' },
  { k: '毎日', v: '散歩 + 読書' },
];

const CONTACT_TOPICS = [
  'エンジニアのウェルビーイング',
  '認知科学の応用',
  '持続可能な開発プラクティス',
  '教育 × テクノロジー',
];

// --- Walk chart ---
const days = Array.from({ length: 30 }, (_, i) => {
  const dow = i % 7;
  const variance = (Math.sin(i * 1.3) * 2200) + (dow === 6 ? 2400 : 0);
  return Math.round(16400 + variance);
});
const maxStep = Math.max(...days);
const minStep = Math.min(...days);
const avgStep = Math.round(days.reduce((a, b) => a + b, 0) / days.length);
const maxIdx = days.indexOf(maxStep);
const W = 720, H = 240;
const points = days.map((v, i) => {
  const x = (i / (days.length - 1)) * W;
  const y = H - ((v - (minStep - 1000)) / (maxStep - (minStep - 1000))) * H;
  return [x, y];
});
const linePath = points.map(([x, y], i) => (i === 0 ? `M${x},${y}` : `L${x},${y}`)).join(' ');
const areaPath = `${linePath} L${W},${H} L0,${H} Z`;
const lineLen = 2200;

// --- Hero title spans ---
type Letter = { ch: string; delay: number; italic?: boolean; highlight?: boolean };
const buildSpans = (text: string, baseDelay: number, opts: { italic?: boolean; highlight?: boolean } = {}): Letter[] =>
  Array.from(text).map((ch, i) => ({
    ch: ch === ' ' ? '\u00A0' : ch,
    delay: (baseDelay + i) * 0.04,
    italic: opts.italic,
    highlight: opts.highlight,
  }));
const titlePart1 = buildSpans('ものをつくり、', 0);
const titleHighlight = buildSpans('人', 7, { italic: true, highlight: true });
const titlePart2 = buildSpans('をつくる。', 8);

const META_RAIL = [
  { mono: '舘 勇紀', text: 'Yuki Tachi' },
  { mono: 'est. 1978', text: '48 years lived' },
  { mono: 'donut service', text: 'Independent · 9 years' },
  { mono: 'kawasaki, jp', text: 'Tamagawa daily' },
];

const NAV_LINKS = [
  ['#about', 'About'],
  ['#walk', 'Walk'],
  ['#stack', 'Stack'],
  ['#brainsync', 'Products'],
  ['#contact', 'Contact'],
];

const BRAINSYNC_REASONS = [
  { n: '01', t: 'なぜ今か', body: 'AI コーディング時代、人間の認知が最後のボトルネック。長時間のコードレビューと意思決定で、エンジニアの認知負荷は過去最大。' },
  { n: '02', t: 'なぜ舘か', body: 'Sony 14 年・独立 9 年。Hardware から Cloud までの全体観 × Frankl 哲学 × 認知科学への深い関心。' },
  { n: '03', t: 'なぜ今、話すか', body: 'プロダクトはアルファ。早期パートナー・投資家との対話を始めたい段階。長期視点での共創を歓迎。' },
];

const BRAINSYNC_META = [
  { k: 'Target', v: '全ソフトウェアエンジニア' },
  { k: 'Method', v: '認知科学 × トレーニング' },
  { k: 'Stack', v: 'Flutter, Python, Docker' },
];

const NUTRI_META = [
  { k: 'Audience', v: '栄養を扱うすべての人' },
  { k: 'Form', v: 'Web app + MCP server' },
  { k: 'Stack', v: 'Next.js, NextAuth, Stripe, WinterCMS' },
];

const NUTRI_TOOLS = [
  { branch: '├─', fn: 'search_food', arg: '(query)' },
  { branch: '├─', fn: 'get_nutrients', arg: '(food_id)' },
  { branch: '├─', fn: 'calculate_pfc', arg: '(meal)' },
  { branch: '├─', fn: 'compare_foods', arg: '(ids[])' },
  { branch: '├─', fn: 'daily_summary', arg: '(date)' },
  { branch: '└─', fn: 'recommend_intake', arg: '(profile)' },
];

const NUTRI_REASONS = [
  { n: '01', t: 'なぜインフラか', body: 'アプリは UI を変えれば作り直せるが、データは正しく整えられた瞬間から長く価値を持ち続ける。食品成分データはまさにそういう種類のデータ。' },
  { n: '02', t: 'なぜ MCP か', body: '栄養データは「アプリの中」だけにあるべきものではない。食事記録、レシピ生成、ヘルスケア連携——MCP として公開することで、ユーザーの業務フローから直接呼び出せる。' },
  { n: '03', t: 'なぜ今か', body: '2026 年 2 月に本番ローンチ、Stripe 決済稼働中。30 日無料トライアルで利用者を募りながら、個人の栄養管理から専門用途まで使い方の広がりを観察している段階。' },
];

const NUTRI_STATS = [
  { v: '2,538', l: 'Foods indexed', k: '食品' },
  { v: '46', l: 'Nutrients per food', k: '栄養素' },
  { v: '6', l: 'MCP tools', k: 'ツール' },
  { v: 'Feb 2026', l: 'Production launch', k: '本番ローンチ' },
];
---

<Layout
  title="Yuki Tachi - Individual Business Owner / Software Engineer | Donut Service"
  description="半導体（シリコン）からAI-クラウドまでをカバーする唯一無二のフルスタックエンジニア。エンジニアのウェルビーイングと持続可能な開発を追求。"
  canonical="/"
  ogType="website"
  ogImage="/profile.jpg"
>
  <!-- NAV -->
  <nav class="rnav" id="rnav">
    <div class="rnav__brand">
      <span class="rnav__logo">y</span>
      <span class="rnav__name">Tachi</span>
    </div>
    <div class="rnav__links">
      {NAV_LINKS.map(([href, label]) => (
        <a href={href}>{label}</a>
      ))}
      <a href="/blog/">Blog</a>
    </div>
    <a href="#contact" class="rnav__cta">Contact <span>→</span></a>
  </nav>

  <main>
    <!-- HERO -->
    <section id="top" class="hero" data-parallax>
      <div class="hero__glow hero__glow--accent" data-parallax-layer="1"></div>
      <div class="hero__glow hero__glow--green" data-parallax-layer="-1"></div>

      <div class="hero__inner">
        <div class="badge">
          <span class="badge__dot"></span>
          新しいプロジェクトの相談を歓迎しています
        </div>

        <div class="hero__grid">
          <div>
            <h1 class="hero__title">
              <span class="hero__line">
                {titlePart1.map((l) => (
                  <span class="reveal-letter" style={`animation-delay:${l.delay}s`}>{l.ch}</span>
                ))}
              </span>
              <span class="hero__line">
                <span class="hero__hi">
                  {titleHighlight.map((l) => (
                    <span class={`reveal-letter${l.italic ? ' is-italic' : ''}${l.highlight ? ' is-hi' : ''}`} style={`animation-delay:${l.delay}s`}>{l.ch}</span>
                  ))}
                  <svg class="hero__squiggle" width="120" height="14" viewBox="0 0 120 14" aria-hidden="true">
                    <path d="M2,8 Q30,2 60,7 T118,6" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" />
                  </svg>
                </span>
                {titlePart2.map((l) => (
                  <span class="reveal-letter" style={`animation-delay:${l.delay}s`}>{l.ch}</span>
                ))}
              </span>
            </h1>

            <p class="hero__lede">
              舘 勇紀 — Donut Service / Software 代表。半導体から AI クラウドまで横断するフルスタックエンジニア。
              毎朝 16,000 歩を歩きながら、エンジニアのウェルビーイングを支えるプロダクトを作っています。
            </p>

            <div class="hero__cta">
              <a href="#brainsync" class="btn btn--solid" data-cursor="hover">
                View BrainSync <span class="btn__arrow">↗</span>
              </a>
              <a href="#about" class="btn btn--ghost" data-cursor="hover">About me</a>
            </div>
          </div>

          <div class="hero__portrait-wrap">
            <div class="portrait" data-cursor="hover" data-parallax-layer="0.6">
              <div class="portrait__bg" data-parallax-layer="0.6"></div>
              <img src="/profile.jpg" alt="Yuki Tachi" class="portrait__img" data-parallax-layer="-2" />
              <div class="portrait__tag portrait__tag--bl">
                <div class="portrait__tag-eyebrow">Now · 2026</div>
                <div class="portrait__tag-text">BrainSync を開発中</div>
              </div>
              <div class="portrait__tag portrait__tag--tr">
                <div class="portrait__tag-eyebrow">Today's walk</div>
                <div class="portrait__tag-big">17,420 <span>steps</span></div>
              </div>
            </div>
          </div>
        </div>

        <div class="meta-rail">
          {META_RAIL.map((m) => (
            <div>
              <div class="meta-rail__mono">{m.mono}</div>
              <div class="meta-rail__text">{m.text}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PHILOSOPHY MARQUEE -->
    <section class="philo">
      <div class="philo__track">
        {[0, 1].map(() => (
          <div class="philo__group">
            <span>Slow software.</span>
            <span class="philo__sep">※</span>
            <span class="philo__faded">Healthy minds.</span>
            <span class="philo__sep">※</span>
            <span>急がず、深く、長く。</span>
            <span class="philo__sep">※</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="section about" data-reveal>
      <div class="section__inner">
        <header class="section__header">
          <div class="section__eyebrow">01 / About</div>
          <h2 class="section__title">独立して9年。</h2>
          <div class="section__sub">14年勤めた Sony を辞めた理由は、ものづくりから人創りへ。</div>
        </header>

        <div class="about__grid">
          <div>
            <div class="about__quote">
              「短期的な成果を追うのではなく、長期的な視点で丁寧に育てていく。そのためには、開発者自身が健康で、持続可能な状態であることが不可欠です。」
            </div>
            <div class="about__attrib">— Yuki Tachi · Founder, Donut Service</div>
          </div>
          <div>
            {STORY.map((line) => (
              <p class="about__p">{line}</p>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- WALK -->
    <section id="walk" class="section walk" data-reveal>
      <div class="section__inner">
        <header class="section__header">
          <div class="section__eyebrow">02 / The walk</div>
          <h2 class="section__title">毎朝、16,000 歩。</h2>
          <div class="section__sub">認知科学が示す「間」の力。</div>
        </header>

        <div class="walk__grid">
          <div>
            <p class="walk__p walk__p--lead">
              朝、川崎の街を <em>1〜2 時間</em> 歩くことから一日が始まる。
              約 <em>16,000 歩</em> の散歩が、思考を整理し、その日の開発の構想を練る時間になる。
            </p>
            <p class="walk__p">
              Viktor Frankl の「刺激と反応の間にある空間」を、文字どおり身体で実装する習慣。
              多摩川を歩きながら、最も創造的な時間が生まれる。
            </p>
            <p class="walk__p">
              週末はカフェで Bill Evans や Miles Davis を聴きながらコーディング。
              ジャズのリズムとコードのリズムがシンクロする瞬間がある。
            </p>
          </div>

          <div class="chart" data-cursor="hover">
            <div class="chart__head">
              <div>
                <div class="chart__eyebrow">Last 30 days · steps</div>
                <div class="chart__big">
                  <span data-countup={avgStep.toString()}>{avgStep.toLocaleString()}</span>
                  <span class="chart__big-sub">avg / day</span>
                </div>
              </div>
              <div class="chart__legend">
                <div>peak <span class="chart__peak">{maxStep.toLocaleString()}</span></div>
                <div>low <span class="chart__low">{minStep.toLocaleString()}</span></div>
              </div>
            </div>

            <svg class="chart__svg" viewBox={`0 0 ${W} ${H + 40}`} preserveAspectRatio="none" aria-hidden="true">
              {[0, 0.25, 0.5, 0.75, 1].map((g) => (
                <line x1={0} x2={W} y1={H * g} y2={H * g} stroke="rgba(34,26,63,0.18)" stroke-dasharray="2 4" />
              ))}
              <defs>
                <linearGradient id="walkGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="var(--c-accent)" stop-opacity="0.35" />
                  <stop offset="100%" stop-color="var(--c-accent)" stop-opacity="0" />
                </linearGradient>
              </defs>
              <path class="chart__area" d={areaPath} fill="url(#walkGrad)" />
              <path class="chart__line" d={linePath} stroke="var(--c-accent)" stroke-width="2" fill="none" stroke-linejoin="round" style={`stroke-dasharray:${lineLen};stroke-dashoffset:${lineLen};`} />
              {points.map(([x, y], i) => (
                <circle class="chart__dot" cx={x} cy={y} r={i === maxIdx ? 5 : 2.5} fill={i === maxIdx ? 'var(--c-accent)' : 'var(--c-ink)'} style={`transition-delay:${i * 0.02 + 1.5}s`} />
              ))}
              <text x="0" y={H + 24} class="chart__axis">30 DAYS AGO</text>
              <text x={W} y={H + 24} class="chart__axis chart__axis--end">TODAY</text>
            </svg>
          </div>
        </div>

        <div class="stats">
          {STATS.map((s) => (
            <div class="stat-card" data-cursor="hover">
              <div class="stat-card__num">
                <span data-countup={s.value}>{s.value}</span><span class="stat-card__unit">{s.unit}</span>
