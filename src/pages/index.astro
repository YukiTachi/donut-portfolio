  <script is:inline>
    (function () {
      // Skills tabs
      const tabs = document.querySelectorAll('.skills__tab');
      const panels = document.querySelectorAll('.skills__panel');
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const idx = tab.getAttribute('data-tab');
          tabs.forEach((t) => {
            t.classList.toggle('is-active', t === tab);
            t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
          });
          panels.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-panel') === idx));
        });
      });

      // Nav scrolled state
      const nav = document.getElementById('rnav');
      if (nav) {
        const onS = () => nav.classList.toggle('is-scrolled', window.scrollY > 40);
        onS();
        window.addEventListener('scroll', onS, { passive: true });
      }

      // BrainSync n-back grid phase rotator
      const cells = document.querySelectorAll('.bs__cell');
      if (cells.length) {
        const seq = [4, 1, 7, 3];
        let phase = 0;
        setInterval(() => {
          cells.forEach((c) => c.classList.remove('is-on'));
          const target = cells[seq[phase]];
          if (target) target.classList.add('is-on');
          phase = (phase + 1) % seq.length;
        }, 1800);
      }

      // Hero parallax
      const hero = document.querySelector('[data-parallax]');
      if (hero && !window.matchMedia('(prefers-reduced-motion: reduce)').matches && !window.matchMedia('(pointer: coarse)').matches) {
        const layers = hero.querySelectorAll('[data-parallax-layer]');
        let target = { x: 0, y: 0 };
        let cur = { x: 0, y: 0 };
        hero.addEventListener('mousemove', (e) => {
          const r = hero.getBoundingClientRect();
          target.x = ((e.clientX - r.left - r.width / 2) / (r.width / 2)) * 8;
          target.y = ((e.clientY - r.top - r.height / 2) / (r.height / 2)) * 8;
        });
        hero.addEventListener('mouseleave', () => { target = { x: 0, y: 0 }; });
        const tick = () => {
          cur.x += (target.x - cur.x) * 0.08;
          cur.y += (target.y - cur.y) * 0.08;
          layers.forEach((el) => {
            const m = parseFloat(el.getAttribute('data-parallax-layer') || '1');
            el.style.setProperty('--px', (cur.x * m) + 'px');
            el.style.setProperty('--py', (cur.y * m) + 'px');
          });
          requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }

      // Walk chart line draw
      const line = document.querySelector('.chart__line');
      const area = document.querySelector('.chart__area');
      const dots = document.querySelectorAll('.chart__dot');
      if (line) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              line.classList.add('is-drawn');
              if (area) area.classList.add('is-drawn');
              dots.forEach((d) => d.classList.add('is-drawn'));
              io.disconnect();
            }
          });
        }, { threshold: 0.3 });
        io.observe(line);
      }
    })();
  </script>
